generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String           @id @default(cuid())
  firebaseUid     String           @unique
  email           String           @unique
  name            String?
  avatarUrl       String?
  createdAt       DateTime         @default(now())
  elderlyProfiles ElderlyProfile[]
  caregiverLinks  Caregiver[]
}

model ElderlyProfile {
  id               String       @id @default(cuid())
  name             String
  avatarUrl        String?
  phone            String
  phoneVerified    Boolean      @default(false)
  language         String       @default("en")
  timezone         String       @default("UTC")
  voiceId          String       @default("21m00Tcm4TlvDq8ikWAM")
  customVoiceName  String?
  emergencyContact       String?
  emergencyPhone         String?
  emergencyPhoneVerified Boolean      @default(false)
  managerId              String
  manager          User         @relation(fields: [managerId], references: [id], onDelete: Cascade)
  caregivers       Caregiver[]
  medications      Medication[]
  reminders        Reminder[]
  assessmentQuestions AssessmentQuestion[]
  assessmentConfig    AssessmentConfig?
  assessmentSessions  AssessmentSession[]
  telegramConversations TelegramConversation[]
  createdAt        DateTime     @default(now())
}

model Caregiver {
  id               String         @id @default(cuid())
  name             String
  email            String?
  phone            String
  phoneVerified    Boolean        @default(false)
  userId           String?
  user             User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  telegramChatId    String?   @unique
  linkCode          String?   @unique
  linkCodeExpiresAt DateTime?
  elderlyProfileId String
  elderlyProfile   ElderlyProfile @relation(fields: [elderlyProfileId], references: [id], onDelete: Cascade)
  telegramConversations TelegramConversation[]
  createdAt        DateTime       @default(now())
}

model Medication {
  id               String         @id @default(cuid())
  name             String
  dosage           String?
  instructions     String?
  elderlyProfileId String
  elderlyProfile   ElderlyProfile @relation(fields: [elderlyProfileId], references: [id], onDelete: Cascade)
  reminders        Reminder[]
  createdAt        DateTime       @default(now())
}

enum ReminderType {
  MEDICATION
  CUSTOM
}

enum Recurrence {
  NONE
  EVERY_1_HOUR
  EVERY_4_HOURS
  EVERY_6_HOURS
  EVERY_8_HOURS
  EVERY_12_HOURS
  DAILY
  EVERY_OTHER_DAY
  WEEKLY
  MONTHLY
  SPECIFIC_DAYS
}

model Reminder {
  id               String         @id @default(cuid())
  type             ReminderType
  title            String
  description      String?
  medicationId     String?
  medication       Medication?    @relation(fields: [medicationId], references: [id], onDelete: SetNull)
  elderlyProfileId String
  elderlyProfile   ElderlyProfile @relation(fields: [elderlyProfileId], references: [id], onDelete: Cascade)
  scheduledTime    String
  scheduledDate    String?
  recurrence       Recurrence     @default(DAILY)
  daysOfWeek       Int[]
  leadTimeMinutes  Int            @default(0)
  active           Boolean        @default(true)
  logs             ReminderLog[]
  createdAt        DateTime       @default(now())
}

enum AssessmentCategory {
  PERSONAL
  ORIENTATION
  PEOPLE
  GENERAL
}

enum AssessmentStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum AssessmentSeverity {
  GREEN
  YELLOW
  RED
}

enum AnswerResult {
  CORRECT
  WRONG
  UNCLEAR
}

enum CallStatus {
  PENDING
  CALLING
  CONFIRMED
  NO_ANSWER
  FAILED
}

model ReminderLog {
  id            String     @id @default(cuid())
  reminderId    String
  reminder      Reminder   @relation(fields: [reminderId], references: [id], onDelete: Cascade)
  status        CallStatus @default(PENDING)
  attemptNumber Int        @default(1)
  calledAt      DateTime?
  respondedAt   DateTime?
  audioUrl      String?
  twilioCallSid String?
  createdAt     DateTime   @default(now())
}

model AssessmentQuestion {
  id               String             @id @default(cuid())
  elderlyProfileId String
  elderlyProfile   ElderlyProfile     @relation(fields: [elderlyProfileId], references: [id], onDelete: Cascade)
  category         AssessmentCategory
  questionText     String
  correctAnswer    String
  answers          AssessmentAnswer[]
  createdAt        DateTime           @default(now())
}

model AssessmentConfig {
  id               String         @id @default(cuid())
  elderlyProfileId String         @unique
  elderlyProfile   ElderlyProfile @relation(fields: [elderlyProfileId], references: [id], onDelete: Cascade)
  scheduledTime    String
  questionsPerCall Int            @default(4)
  active           Boolean        @default(false)
  sessions         AssessmentSession[]
  createdAt        DateTime       @default(now())
}

model AssessmentSession {
  id               String             @id @default(cuid())
  elderlyProfileId String
  elderlyProfile   ElderlyProfile     @relation(fields: [elderlyProfileId], references: [id], onDelete: Cascade)
  configId         String
  config           AssessmentConfig   @relation(fields: [configId], references: [id], onDelete: Cascade)
  date             String
  overallScore     Float?
  status           AssessmentStatus   @default(PENDING)
  summary          String?
  severity         AssessmentSeverity?
  twilioCallSid      String?
  emotionalResponse  String?
  vocalAnalysis      Json?
  answers            AssessmentAnswer[]
  createdAt          DateTime           @default(now())
}

model TelegramConversation {
  id                   String          @id @default(cuid())
  telegramChatId       String          @unique
  telegramUserId       String
  caregiverId          String?
  caregiver            Caregiver?      @relation(fields: [caregiverId], references: [id])
  elderlyProfileId     String?
  elderlyProfile       ElderlyProfile? @relation(fields: [elderlyProfileId], references: [id])
  intent               String          @default("NONE")
  state                Json?
  lastUserMessage      String?
  lastAssistantMessage String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
}

model AssessmentAnswer {
  id            String           @id @default(cuid())
  sessionId     String
  session       AssessmentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionId    String
  question      AssessmentQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionText  String
  correctAnswer String
  elderAnswer   String?
  result        AnswerResult?
  recordingUrl  String?
  orderIndex    Int              @default(0)
  createdAt     DateTime         @default(now())
}
